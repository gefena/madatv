        { "id": "b", "text": { "en": "The way rocks change over time", "he": "\u05d4\u05d3\u05e8\u05da \u05e9\u05d1\u05d4 \u05e1\u05dc\u05e2\u05d9\u05dd \u05de\u05e9\u05ea\u05e0\u05d9\u05dd \u05e2\u05dd \u05d4\u05d6\u05de\u05df" } },
        { "id": "c", "text": { "en": "The slow change of living things over many generations", "he": "\u05d4\u05e9\u05d9\u05e0\u05d5\u05d9 \u05d4\u05d0\u05d8\u05d9 \u05e9\u05dc \u05d9\u05e6\u05d5\u05e8\u05d9\u05dd \u05d7\u05d9\u05d9\u05dd \u05e2\u05dc \u05e4\u05e0\u05d9 \u05d3\u05d5\u05e8\u05d5\u05ea \u05e8\u05d1\u05d9\u05dd" } },
